extends ../_templates/_base.pug


block main
  main
    section.hero.has-bg
      .hero__bg.bg.bg_cover
        picture
          source(media="(max-width: 767px)" srcset="img/hero-bg.png" type="image/png")
          img(src="img/hero-bg.png" alt="Dots...." loading="eager")

      .container.hero__container

        .hero__body
          h1.hero__heading
            span.hero__heading-line
              span.hero__heading-word.hero__heading-word_light 
                span.hero__heading-word-letter W 
                span.hero__heading-word-letter E
                span.hero__heading-word-letter B
              | &nbsp;
              span.hero__heading-word.hero__heading-word_bold 
                span.hero__heading-word-letter S
                span.hero__heading-word-letter T
                span.hero__heading-word-letter U
                span.hero__heading-word-letter D
                span.hero__heading-word-letter I
                span.hero__heading-word-letter O
            span.hero__heading-line
              span.hero__heading-word.hero__heading-word_light 
                span.hero__heading-word-letter D
                span.hero__heading-word-letter I
                span.hero__heading-word-letter G
                span.hero__heading-word-letter I
                span.hero__heading-word-letter T
                span.hero__heading-word-letter A
                span.hero__heading-word-letter L
              | &nbsp;
              span.hero__heading-word.hero__heading-word_bold 
                span.hero__heading-word-letter D
                span.hero__heading-word-letter E
                span.hero__heading-word-letter S
                span.hero__heading-word-letter I
                span.hero__heading-word-letter G
                span.hero__heading-word-letter N

          p.hero__description
            | Веб-студия — создаём сайты, лендинги, интернет-магазины, web-приложения, crm-системы


      .hero__footer
        .container.hero__footer-inner
          a.hero__footer-contact(href="mailto:infodots@yandex.ru") INFODOTS@YANDEX.RU
          a.hero__footer-contact(href="tel:+78002000888") +7 800 200-08-88





    mixin 3d-card(imgUrl)
      .card
        .card__inner
          .card__content
            .card__img 
                img(src=imgUrl, alt="Логтип компании Nike")
            .card__descr
              h3 Nike Logo
              .btn.btn_black Посмотреть


    section.cases
      .container.cases__container
        .cases__grid
          
          +3d-card("img/nike-logo.jpg")
          +3d-card("img/nike-logo.jpg")
          +3d-card("img/nike-logo.jpg")
          +3d-card("img/nike-logo.jpg")
          +3d-card("img/nike-logo.jpg")
          +3d-card("img/nike-logo.jpg")
